    SELECT 
        payroll_year,               
        industry_name,      
        industry_branch_code,       
        priemerná_mzda_odvetví, 
        LAG(priemerná_mzda_odvetví, 1) OVER (
            PARTITION BY industry_name       
            ORDER BY payroll_year   
        ) AS mzda_minuly_rok 
    FROM 
        avg_industry_salary 
    WHERE 
        payroll_year BETWEEN 2000 AND 2021
) AS poddopyt_mzdy
ORDER BY 
    industry_name,
    payroll_year;

