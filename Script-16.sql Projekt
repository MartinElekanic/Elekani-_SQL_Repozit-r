 ---Vzorec pre konečný výpočet kg chleba a l mlieka dostupných za priemernú mzdu v rozsahu rokov,spoločných pre tabuľky c-payroll a c.price

CREATE VIEW konečný_prehľad_množstva AS
SELECT 
    afp.rok,
    ip.industry_name, 
    ROUND(ip.avg_wage::numeric, 2) AS priemerna_mzda,
    ROUND(afp.average_bread_price::numeric, 2) AS cena_chleba,
    ROUND(afp.average_milk_price::numeric, 2) AS cena_mlieka,
    
