---Najprv idem vypočítať rast hdp pre Česko za roky 2006-2018(spoločné s tabuľkami miezd a potravín)

CREATE VIEW rast_hdp_CZ AS
SELECT
    year,
    country,
    gdp,
    ROUND(((gdp - prev_gdp) / prev_gdp) * 100)::numeric,
    2 
    AS medzirocne_hdp
FROM (
    SELECT
        e.year,
        c.country,
        e.gdp,
        LAG(e.gdp) OVER (ORDER BY e.year) AS prev_gdp
    FROM economies e
    JOIN countries c
        ON e.country = c.country
    WHERE c.country = 'Czech Republic'
      AND e.year BETWEEN 2006 AND 2018
) t;
 
