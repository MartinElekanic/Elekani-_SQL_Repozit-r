--- ďalej vypočítam ceny medzi rokmi
CREATE VIEW food_yoy_prices AS 
SELECT
  food_name,
  month_start,
  total_price, 
  ---Extrahovanie mesiaca a roka z formátu dátumu v primárnej tabuľke
  extract(MONTH FROM month_start) AS MONTH,
  extract(YEAR FROM month_start) AS YEAR,
  ---month over month, výpočet medzi mesiacmi
  CASE
    WHEN LAG(total_price, 1) OVER (PARTITION BY food_name ORDER BY month_start) IS NULL THEN NULL
    WHEN LAG(total_price, 1) OVER (PARTITION BY food_name ORDER BY month_start) = 0 THEN NULL
    ELSE (total_price - LAG(total_price, 1) OVER (PARTITION BY food_name ORDER BY month_start))
         / NULLIF(LAG(total_price, 1) OVER (PARTITION BY food_name ORDER BY month_start), 0) * 100
  END AS pct_change_mom,
  ---yoy, výpočet medzi rokmi
  CASE
    WHEN LAG(total_price, 12) OVER (PARTITION BY food_name ORDER BY month_start) IS NULL THEN NULL
    WHEN LAG(total_price, 12) OVER (PARTITION BY food_name ORDER BY month_start) = 0 THEN NULL
    ELSE (total_price - LAG(total_price, 12) OVER (PARTITION BY food_name ORDER BY month_start))
         / NULLIF(LAG(total_price, 12) OVER (PARTITION BY food_name ORDER BY month_start), 0) * 100
  END AS pct_change_yoy
FROM cena_na_mesiac;

