CREATE VIEW europe_data AS
SELECT
    c.country,
    c.continent,
    e.year,
    e.gdp,
    e.gini,
    e.population
FROM economies e
LEFT JOIN countries c
    ON e.country = c.country
WHERE c.continent = 'Europe'
  AND e.year BETWEEN 2006 AND 2018
ORDER BY c.country, e.year;


SELECT * FROM europe_data;

