---Nasleduje porovnanie miezd odvetví počas rokov

CREATE VIEW Vyvoj_miezd AS 
SELECT 
    industry_name,
    payroll_year,
    priemerná_mzda_odvetví,
    -- 1. Výpočet mzdy za minulý rok
    LAG(priemerná_mzda_odvetví, 1) OVER (
        PARTITION BY industry_name       
        ORDER BY payroll_year   
    ) AS mzda_minuly_rok,
    -- 2. Priamy výpočet trendu v percentách (zopakujeme LAG funkciu)
    ROUND(
        ((priemerná_mzda_odvetví - LAG(priemerná_mzda_odvetví, 1) OVER (
            PARTITION BY industry_name       
            ORDER BY payroll_year   
        )) / LAG(priemerná_mzda_odvetví, 1) OVER (
            PARTITION BY industry_name       
            ORDER BY payroll_year   
        )) * 100,
        2
    ) AS trend_v_percentach
FROM 
    avg_industry_salary 
WHERE 
    payroll_year BETWEEN 2000 AND 2021
ORDER BY 
    industry_name,
    payroll_year;

SELECT * FROM Vyvoj_miezd;

